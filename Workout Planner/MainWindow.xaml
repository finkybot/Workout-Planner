<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="Workout_Planner.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Workout_Planner"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="Workout Planner">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock
            Text="Workout Planner"
            FontSize="24"
            FontWeight="Bold"
            HorizontalAlignment="Center"
            Margin="10" />

        <!-- Content + Navigation -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="0.18*" />
            </Grid.ColumnDefinitions>

            <!-- Active View -->
            <ContentControl
                x:Name="ContentArea"
                Grid.Column="0"
                HorizontalContentAlignment="Stretch"
                VerticalContentAlignment="Stretch" />

            <!-- Navigation Buttons -->
            <Grid Grid.Column="1" Margin="10">
                <StackPanel Orientation="Vertical" Spacing="10"
                            VerticalAlignment="Center">
                    <Button Content="Exercise" HorizontalAlignment="Stretch" Click="ExerciseNav_Click" />
                    <Button Content="Workout Planner" HorizontalAlignment="Stretch" Click="PlannerNav_Click" />
                    <Button Content="Setup Workouts" HorizontalAlignment="Stretch" Click="WorkoutNav_Click" />
                </StackPanel>

                <Button
                    x:Name="EditExerciseButton"
                    Content="Edit Exercise"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Bottom"
                    Opacity="0"
                    IsHitTestVisible="False"
                    Click="EditExerciseButton_Click" />
            </Grid>
        </Grid>
    </Grid>
</Window>
