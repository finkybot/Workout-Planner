<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="Workout_Planner.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Workout_Planner"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="Workout Planner">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Title -->
        <Border
            Grid.Row="0"
            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="0,0,0,1"
            Padding="10">
            <TextBlock
                Text="Workout Planner"
                FontSize="24"
                FontWeight="Bold"
                HorizontalAlignment="Center" />
        </Border>

        <!-- Content + Navigation -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="0.18*" />
            </Grid.ColumnDefinitions>

            <!-- Active View -->
            <ContentControl
                x:Name="ContentArea"
                Grid.Column="0"
                HorizontalContentAlignment="Stretch"
                VerticalContentAlignment="Stretch" />

            <!-- Navigation Panel -->
            <Border
                Grid.Column="1"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1,0,0,0"
                CornerRadius="8,0,0,8">
                <Grid Margin="10">
                    <Button
                        Content="Exit"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Top"
                        Click="ExitButton_Click" />

                    <StackPanel Orientation="Vertical" Spacing="10"
                                VerticalAlignment="Center">
                        <Button Content="Exercise" HorizontalAlignment="Stretch" Click="ExerciseNav_Click" />
                        <Button Content="Workout Planner" HorizontalAlignment="Stretch" Click="PlannerNav_Click" />
                        <Button Content="Setup Workouts" HorizontalAlignment="Stretch" Click="WorkoutNav_Click" />
                    </StackPanel>

                    <Button
                        x:Name="EditExerciseButton"
                        Content="Edit Exercise"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Bottom"
                        Opacity="0"
                        IsHitTestVisible="False"
                        Click="EditExerciseButton_Click" />
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
