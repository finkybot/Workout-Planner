<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="Workout_Planner.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Workout_Planner"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="Workout Planner">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock
            Text="Workout Planner"
            FontSize="24"
            FontWeight="Bold"
            HorizontalAlignment="Center"
            Margin="10" />

        <!-- Two-column layout -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="2*" />
            </Grid.ColumnDefinitions>

            <!-- First Stack (Left) -->
            <Grid Grid.Column="0">
                <ListView
                    x:Name="WorkoutListView"
                    SelectionChanged="WorkoutListView_SelectionChanged"
                    Margin="10">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="Padding" Value="0" />
                            <Setter Property="Margin" Value="0" />
                            <Setter Property="MinHeight" Value="25" />
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="local:Exercise">
                            <TextBlock Text="{Binding Name}" />
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>

            <!-- Second Stack (Right) - Exercise Details -->
            <StackPanel Grid.Column="1" Orientation="Vertical" Margin="10">
                <TextBlock
                    x:Name="ExerciseNameTextBlock"
                    Text="No exercise selected"
                    FontSize="18"
                    FontWeight="Bold"
                    Margin="0,0,0,10" />

                <TextBlock
                    Text="Description:"
                    FontWeight="Bold"
                    Margin="0,0,0,5" />
                <TextBlock
                    x:Name="ExerciseDescriptionTextBlock"
                    Text=""
                    TextWrapping="Wrap"
                    Margin="0,0,0,15" />

                <TextBlock
                    Text="Weightlifting:"
                    FontWeight="Bold"
                    Margin="0,0,0,5" />
                <TextBlock
                    x:Name="IsWeightLiftingTextBlock"
                    Text=""
                    Margin="0,0,0,15" />
            </StackPanel>
        </Grid>

        <!-- Button Bar -->
        <Grid Grid.Row="2" Margin="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!-- Left buttons -->
            <StackPanel
                Orientation="Horizontal"
                Grid.Column="0"
                Spacing="10">
                <Button
                    Content="Add Workout"
                    Click="AddWorkoutButton_Click" />

                <Button
                    Content="Remove Workout"
                    Click="RemoveWorkoutButton_Click" />
            </StackPanel>

            <!-- Right button -->
            <Button
                Content="Edit Workout"
                Grid.Column="2"
                Click="EditWorkoutButton_Click" />
        </Grid>
    </Grid>
</Window>
