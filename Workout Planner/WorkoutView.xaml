<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Workout_Planner.WorkoutView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:Workout_Planner"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="50" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Left column -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <TextBlock
                    Grid.Row="0"
                    Text="Plans"
                    FontSize="16"
                    FontWeight="SemiBold"
                    Margin="10,10,10,0" />

                <ListView
                    Grid.Row="1"
                    x:Name="PlanListView"
                    SelectionChanged="PlanListView_SelectionChanged"
                    Margin="10">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="Padding" Value="0" />
                            <Setter Property="Margin" Value="0" />
                            <Setter Property="MinHeight" Value="25" />
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="local:Plan">
                            <TextBlock Text="{x:Bind PlanName, Mode=OneWay}" />
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>

            <!-- Right column -->
            <Grid Grid.Column="1" Margin="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="2*" />
                </Grid.RowDefinitions>

                <TextBlock
                    Grid.Row="0"
                    Text="Workouts"
                    FontSize="16"
                    FontWeight="SemiBold"
                    Margin="0,0,0,0" />

                <ListView
                    Grid.Row="1"
                    x:Name="WorkoutListView"
                    SelectionChanged="WorkoutListView_SelectionChanged"
                    Tapped="WorkoutListView_Tapped"
                    Margin="0,10,0,0">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="Padding" Value="0" />
                            <Setter Property="Margin" Value="0" />
                            <Setter Property="MinHeight" Value="25" />
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="local:Workout">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="{x:Bind DisplayName}" />
                                <TextBlock Text="{x:Bind Date}" Opacity="0.6" />
                            </StackPanel>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

                <TextBlock
                    Grid.Row="2"
                    x:Name="DetailListTitle"
                    Text=""
                    FontSize="16"
                    FontWeight="SemiBold"
                    Margin="0,10,0,0"
                    Visibility="Collapsed" />

                <ListView
                    Grid.Row="3"
                    x:Name="PlanExercisesListView"
                    SelectionChanged="PlanExercisesListView_SelectionChanged"
                    Visibility="Collapsed"
                    Margin="0,10,0,0">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="Padding" Value="0" />
                            <Setter Property="Margin" Value="0" />
                            <Setter Property="MinHeight" Value="25" />
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="local:Exercise">
                            <TextBlock Text="{x:Bind Name, Mode=OneWay}" />
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

                <ListView
                    Grid.Row="3"
                    x:Name="WorkoutExercisesListView"
                    SelectionChanged="WorkoutExercisesListView_SelectionChanged"
                    Visibility="Collapsed"
                    Margin="0,10,0,0">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="Padding" Value="0" />
                            <Setter Property="Margin" Value="0" />
                            <Setter Property="MinHeight" Value="25" />
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="local:CurrentExercise">
                            <TextBlock Text="{x:Bind Exercise.Name, Mode=OneWay}" />
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>
        </Grid>

        <!-- Info bar (fixed height) -->
        <Grid Grid.Row="1" Margin="10,0,10,0">
            <!-- Description panel -->
            <StackPanel
                x:Name="DescriptionPanel"
                Orientation="Vertical"
                VerticalAlignment="Center"
                Visibility="Collapsed">
                <TextBlock
                    Text="Description:"
                    FontWeight="Bold" />
                <TextBlock
                    x:Name="DescriptionTextBlock"
                    Text=""
                    TextWrapping="NoWrap"
                    TextTrimming="CharacterEllipsis" />
            </StackPanel>

            <!-- Exercise edit panel -->
            <StackPanel
                x:Name="ExerciseEditPanel"
                Orientation="Horizontal"
                Spacing="15"
                VerticalAlignment="Center"
                Visibility="Collapsed">
                <TextBlock
                    x:Name="ExerciseNameTextBlock"
                    Text=""
                    FontWeight="Bold"
                    VerticalAlignment="Center"
                    TextWrapping="Wrap"
                    TextTrimming="CharacterEllipsis"
                    MaxWidth="200" />
                <StackPanel Orientation="Horizontal" Spacing="5" VerticalAlignment="Center">
                    <TextBlock Text="Sets:" VerticalAlignment="Center" />
                    <NumberBox
                        x:Name="SetsNumberBox"
                        Minimum="1"
                        SpinButtonPlacementMode="Inline"
                        Width="140"
                        ValueChanged="ExerciseValueChanged" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="5" VerticalAlignment="Center">
                    <TextBlock Text="Reps:" VerticalAlignment="Center" />
                    <NumberBox
                        x:Name="RepsNumberBox"
                        Minimum="1"
                        SpinButtonPlacementMode="Inline"
                        Width="140"
                        ValueChanged="ExerciseValueChanged" />
                </StackPanel>
                <StackPanel
                    x:Name="WeightPanel"
                    Orientation="Horizontal"
                    Spacing="5"
                    VerticalAlignment="Center"
                    Visibility="Collapsed">
                    <TextBlock Text="Weight (kg):" VerticalAlignment="Center" />
                    <NumberBox
                        x:Name="WeightNumberBox"
                        Minimum="0"
                        SpinButtonPlacementMode="Inline"
                        Width="140"
                        ValueChanged="ExerciseValueChanged" />
                </StackPanel>
            </StackPanel>
        </Grid>

        <!-- Bottom bar -->
        <Grid Grid.Row="2" Margin="10" MinHeight="36">
            <Button
                x:Name="RemoveWorkoutButton"
                Content="Remove Workout"
                HorizontalAlignment="Right"
                VerticalAlignment="Center"
                Visibility="Collapsed"
                Click="RemoveWorkoutButton_Click" />

            <Button
                x:Name="CreateWorkoutButton"
                Content="Create New Workout"
                HorizontalAlignment="Right"
                VerticalAlignment="Center"
                Visibility="Collapsed"
                Click="CreateWorkoutButton_Click" />
        </Grid>
    </Grid>
</UserControl>