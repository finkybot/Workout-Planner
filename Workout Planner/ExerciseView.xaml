<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Workout_Planner.ExerciseView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Workout_Planner"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="2*" />
            </Grid.ColumnDefinitions>

            <!-- Exercise List -->
            <Grid Grid.Column="0">
                <ListView
                    x:Name="ExerciseListView"
                    SelectionChanged="ExerciseListView_SelectionChanged"
                    Tapped="ExerciseListView_Tapped"
                    Margin="10">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="Padding" Value="0" />
                            <Setter Property="Margin" Value="0" />
                            <Setter Property="MinHeight" Value="25" />
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="local:Exercise">
                            <TextBlock Text="{x:Bind Name, Mode=OneWay}" />
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>

            <!-- Exercise Details -->
            <StackPanel Grid.Column="1" Orientation="Vertical" Margin="10">
                <TextBlock
                    x:Name="ExerciseNameTextBlock"
                    Text="No exercise selected"
                    FontSize="18"
                    FontWeight="Bold"
                    Margin="0,0,0,10" />

                <TextBlock Text="Description:" FontWeight="Bold" Margin="0,0,0,5" />
                <TextBlock
                    x:Name="ExerciseDescriptionTextBlock"
                    Text=""
                    TextWrapping="Wrap"
                    Margin="0,0,0,15" />

                <TextBlock Text="Weightlifting:" FontWeight="Bold" Margin="0,0,0,5" />
                <TextBlock
                    x:Name="IsWeightLiftingTextBlock"
                    Text=""
                    Margin="0,0,0,15" />

                <TextBlock Text="Weight Type:" FontWeight="Bold" Margin="0,0,0,5" />
                <TextBlock
                    x:Name="WeightTypeTextBlock"
                    Text=""
                    Margin="0,0,0,15" />
            </StackPanel>
        </Grid>

        <!-- Button Bar -->
        <Grid Grid.Row="1" Margin="10">
            <StackPanel Orientation="Horizontal" Spacing="10">
                <Button x:Name="AddExerciseButton" Content="Add Exercise" Click="AddExerciseButton_Click" />
                <Button  x:Name="RemoveExerciseButton" Content="Remove Exercise" Click="RemoveExerciseButton_Click" />
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>