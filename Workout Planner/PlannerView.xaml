<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Workout_Planner.PlannerView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:Workout_Planner"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Left column: Plans + Exercises -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="2*" />
                </Grid.RowDefinitions>

                <TextBlock
                    Grid.Row="0"
                    Text="Plans"
                    FontSize="16"
                    FontWeight="SemiBold"
                    Margin="10,10,10,0" />

                <ListView
                    Grid.Row="1"
                    x:Name="PlanListView"
                    SelectionChanged="PlanListView_SelectionChanged"
                    Margin="10">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="Padding" Value="0" />
                            <Setter Property="Margin" Value="0" />
                            <Setter Property="MinHeight" Value="25" />
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="local:Plan">
                            <TextBlock Text="{x:Bind PlanName, Mode=OneWay}" />
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

                <TextBlock
                    Grid.Row="2"
                    Text="Exercises"
                    FontSize="16"
                    FontWeight="SemiBold"
                    Margin="10,10,10,0" />

                <ListView
                    Grid.Row="3"
                    x:Name="AllExercisesListView"
                    CanDragItems="True"
                    DragItemsStarting="AllExercisesListView_DragItemsStarting"
                    SelectionChanged="AllExercisesListView_SelectionChanged"
                    Margin="10">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="Padding" Value="0" />
                            <Setter Property="Margin" Value="0" />
                            <Setter Property="MinHeight" Value="25" />
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="local:Exercise">
                            <TextBlock Text="{x:Bind Name, Mode=OneWay}" />
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>

            <!-- Right column: Plan name + Plan exercises -->
            <Grid Grid.Column="1" Margin="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,10">
                    <TextBlock
                        x:Name="PlanNameTextBlock"
                        Text="No plan selected"
                        FontSize="18"
                        FontWeight="Bold"
                        Tapped="PlanNameTextBlock_Tapped" />
                    <TextBox
                        x:Name="PlanNameTextBox"
                        FontSize="18"
                        FontWeight="Bold"
                        Visibility="Collapsed"
                        KeyDown="PlanNameTextBox_KeyDown"
                        LostFocus="PlanNameTextBox_LostFocus" />
                </Grid>

                <ListView
                    Grid.Row="1"
                    x:Name="ExerciseListView"
                    AllowDrop="True"
                    CanReorderItems="True"
                    CanDragItems="True"
                    DragOver="ExerciseListView_DragOver"
                    Drop="ExerciseListView_Drop"
                    SelectionChanged="ExerciseListView_SelectionChanged"
                    Margin="0,10,0,0">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="Padding" Value="0" />
                            <Setter Property="Margin" Value="0" />
                            <Setter Property="MinHeight" Value="25" />
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="local:Exercise">
                            <TextBlock Text="{x:Bind Name, Mode=OneWay}" />
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>
        </Grid>

        <Grid Grid.Row="1" Margin="10">
            <StackPanel Orientation="Horizontal" Spacing="10">
                <Button
                    x:Name="AddExerciseToPlanButton"
                    Content="Add Exercise to Plan"
                    Visibility="Collapsed"
                    Click="AddExerciseToPlanButton_Click" />
                <Button
                    x:Name="RemoveExerciseButton"
                    Content="Remove Exercise"
                    Visibility="Collapsed"
                    Click="RemoveExerciseButton_Click" />
                <StackPanel Orientation="Vertical" VerticalAlignment="Center">
                    <TextBlock
                        Text="Description:"
                        FontWeight="SemiBold"
                        Margin="0,0,0,4" />
                    <TextBlock
                        x:Name="ExerciseDescriptionTextBlock"
                        Text=""
                        TextWrapping="Wrap"
                        MaxWidth="400" />
                </StackPanel>
            </StackPanel>

            <Button
                x:Name="NewPlanButton"
                Content="New Plan"
                HorizontalAlignment="Right"
                VerticalAlignment="Bottom"
                Click="NewPlanButton_Click" />
        </Grid>
    </Grid>
</UserControl>